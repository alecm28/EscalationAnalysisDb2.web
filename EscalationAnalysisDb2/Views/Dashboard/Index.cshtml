@model EscalationAnalysisDb2.Models.DashboardViewModel

<div id="dashboardContent">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Escalations</h2>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Users" asp-action="Index" class="btn btn-secondary mt-2">
                    Manage Users
                </a>
            }
        </div>

        <button class="btn btn-primary" onclick="exportDashboard()">
            Export dashboard
        </button>
    </div>

    <div class="row">

        <!-- IZQUIERDA -->
        <div class="col-md-9">

            <div class="row mb-4">

                <div class="col-md-4">
                    <div class="card p-3">
                        <small>Total escalations</small>
                        <h2 style="color:#bf0c0c;">@Model.TotalEscalations</h2>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card p-3">
                        <small>Total escalated cases</small>
                        <h2 style="color:#f59e0b;">@Model.TotalCases</h2>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card p-3">
                        <small>Most escalated version</small>
                        <h2>@Model.MostImpactedVersion</h2>
                    </div>
                </div>

            </div>

            <!-- TREND CHART -->
            <div class="card p-3 mb-4">
                <h5>Escalation trends</h5>
                <canvas id="trendChart"></canvas>
            </div>

            <div class="row">

                <!-- TOP ACCOUNTS -->
                <div class="col-md-4">
                    <div class="card p-3">
                        <h6>Top escalated customers</h6>
                        @foreach (var acc in Model.TopAccounts)
                        {
                            <div>@acc</div>
                        }
                    </div>
                </div>

                <!-- TOP OWNERS -->
                <div class="col-md-4">
                    <div class="card p-3">
                        <h6>Top escalated owners</h6>
                        @foreach (var owner in Model.TopOwners)
                        {
                            <div>@owner</div>
                        }
                    </div>
                </div>

                <!-- INSIGHTS -->
                <div class="col-md-4">
                    <div class="card p-3">
                        <h6>Insights</h6>
                        <div>@Model.Insight1</div>
                        <div>@Model.Insight2</div>
                        <div>@Model.Insight3</div>
                    </div>
                </div>

            </div>

        </div>

        <!-- DERECHA (FILTROS) -->
        <div class="col-md-3">

            <div class="card p-3">

                <!-- FORM FILTROS -->
                <form method="get" asp-controller="Dashboard" asp-action="Index">

                    <h5>Filters</h5>

                    <!-- MONTH -->
                    <label>Month</label>
                    <select name="month" class="form-control mb-3">
                        <option value="">All</option>
                        <option value="1">Jan</option>
                        <option value="2">Feb</option>
                        <option value="3">Mar</option>
                        <option value="4">Apr</option>
                        <option value="5">May</option>
                        <option value="6">Jun</option>
                        <option value="7">Jul</option>
                        <option value="8">Aug</option>
                        <option value="9">Sep</option>
                        <option value="10">Oct</option>
                        <option value="11">Nov</option>
                        <option value="12">Dec</option>
                    </select>

                    <!-- SEVERITY -->
                    <label>Severity</label>
                    <div class="mb-3">
                        <div><input type="checkbox" name="severity" value="1" /> Critical</div>
                        <div><input type="checkbox" name="severity" value="2" /> High</div>
                        <div><input type="checkbox" name="severity" value="3" /> Moderate</div>
                        <div><input type="checkbox" name="severity" value="4" /> Low</div>
                    </div>

                    <!-- REGION -->
                    <label>Region</label>
                    <input type="text" name="region" class="form-control mb-3" placeholder="Americas" />

                    <!-- VERSION -->
                    <label>Product version</label>
                    <input type="text" name="version" class="form-control mb-3" placeholder="11.5" />

                    <!-- BOTONES -->
                    <div class="d-flex gap-2">

                        <!-- FIX CRASH -->
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary w-50">
                            Reset
                        </a>

                        <button type="submit" class="btn btn-primary w-50">
                            Apply
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas"></script>

    <script>

        const trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendLabels ?? new List<string>()));
        const trendValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendValues ?? new List<int>()));

        const ctx = document.getElementById('trendChart').getContext('2d');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: trendLabels,
                datasets: [{
                    data: trendValues,
                    borderColor: '#4c1d95',
                    backgroundColor: 'rgba(76,29,149,0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    pointBackgroundColor: '#4c1d95',
                    pointBorderColor: '#ffffff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                }
            }
        });

        function exportDashboard() {
            const element = document.getElementById("dashboardContent");

            html2canvas(element).then(canvas => {
                const link = document.createElement('a');
                link.download = 'dashboard.png';
                link.href = canvas.toDataURL();
                link.click();
            });
        }

    </script>
}