@model EscalationAnalysisDb2.Domain.Entities.AppUser

<div class="container mt-4">

    <div class="card p-4 shadow-sm" style="max-width:500px; margin:auto; border-radius:12px;">

        <!-- titulo -->
        <h4 class="mb-3">Edit User</h4>
        <p class="text-muted mb-4">Update user information</p>

        <!-- formulario editar -->
        <form asp-action="Edit" method="post" autocomplete="off">

            <!-- id oculto -->
            <input type="hidden" asp-for="AppUserId" />

            <!-- errores -->
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- email bloqueado -->
            <div class="mb-3">
                <label class="form-label">Email</label>

                <input asp-for="Email"
                       class="form-control"
                       readonly
                       style="background-color:#f8f9fa; cursor:not-allowed;" />

                <small class="text-muted">
                    Email cannot be changed after user creation.
                </small>
            </div>

            <!-- nueva password opcional -->
            <div class="mb-3">
                <label class="form-label">New Password</label>

                <input name="NewPassword"
                       type="password"
                       class="form-control"
                       placeholder="Leave blank to keep current password" />
            </div>

            <!-- rol -->
            <div class="mb-3">
                <label class="form-label">Role</label>

                <select asp-for="Role" class="form-control">
                    <option value="Admin">Admin</option>
                    <option value="User">User</option>
                </select>
            </div>

            <!-- activo -->
            <div class="form-check mb-4">
                <input asp-for="IsActive"
                       type="checkbox"
                       class="form-check-input" />

                <label class="form-check-label">
                    Active
                </label>
            </div>

            <!-- botones -->
            <div class="d-flex gap-2">

                <button type="submit" class="btn btn-primary w-50">
                    Update
                </button>

                <a asp-controller="Users"
                   asp-action="Index"
                   class="btn btn-outline-secondary w-50">
                    Back to list
                </a>

            </div>

        </form>

    </div>

</div>