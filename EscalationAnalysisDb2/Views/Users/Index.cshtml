@model List<EscalationAnalysisDb2.Domain.Entities.AppUser>

<div class="container-fluid">

    <!-- alertas -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 style="color:#4c1d95;">Users</h2>
            <small class="text-muted">Manage system users</small>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            + Create New User
        </a>
    </div>

    <!-- tarjeta principal -->
    <div class="card shadow-sm p-3">

        <table class="table table-hover align-middle">

            <thead style="background-color:#f3f0ff;">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <!-- username -->
                        <td>@user.Username</td>

                        <!-- email -->
                        <td>@user.Email</td>

                        <!-- rol -->
                        <td>
                            <span class="badge bg-secondary">
                                @user.Role
                            </span>
                        </td>

                        <!-- estado -->
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>

                        <!-- acciones -->
                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-id="@user.AppUserId"
                               class="btn btn-sm btn-outline-primary me-2">
                                Edit
                            </a>

                            @if (user.IsActive)
                            {
                                <a asp-action="Deactivate"
                                   asp-route-id="@user.AppUserId"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Are you sure you want to deactivate this user?');">
                                    Deactivate
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary" disabled>
                                    Inactive
                                </button>
                            }

                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>