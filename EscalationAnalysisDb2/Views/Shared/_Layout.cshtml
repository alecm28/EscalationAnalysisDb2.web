<!DOCTYPE html>
<html lang="en">
<head>
    <!-- configuracion base -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EscalationAnalysisDb2</title>

    <!-- estilos -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- librerias -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas"></script>
</head>

<body>

    <!-- barra superior -->
    <div class="topbar">
        <div class="d-flex align-items-center w-100 justify-content-between">

            <!-- lado izquierdo -->
            <div class="d-flex align-items-center gap-3">
                <span onclick="toggleSidebar()" style="font-size:20px; cursor:pointer;">☰</span>

                <span style="font-size:22px; font-weight:500;">
                    IBM
                </span>
            </div>

            <!-- lado derecho -->
            <div class="d-flex align-items-center gap-3">

                @if (User.Identity.IsAuthenticated)
                {
                    <span style="color:white; font-weight:500;">
                        Hi, @User.Identity.Name.Split('@')[0]
                    </span>

                    <a href="/Auth/Logout" class="btn btn-outline-light btn-sm">
                        Logout
                    </a>
                }

            </div>

        </div>
    </div>

    <div class="main-container">

        <!-- menu lateral -->
        <div id="sidebar" class="sidebar">

            <ul>

                <li>
                    <a asp-controller="Dashboard" asp-action="Index">
                        Dashboard
                    </a>
                </li>

                <li>
                    <a asp-controller="Upload" asp-action="Index">
                        Upload
                    </a>
                </li>

                <li>
                    <a asp-controller="Reports" asp-action="Index">
                        Report History
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <!-- opciones admin -->
                    <li>
                        <a asp-controller="Users" asp-action="Index">
                            Users
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Admin" asp-action="Index">
                            System Overview
                        </a>
                    </li>
                }
                else
                {
                    <!-- opcion usuario normal -->
                    <li>
                        <a asp-controller="Help" asp-action="Index">
                            Help
                        </a>
                    </li>
                }

            </ul>

        </div>

        <!-- contenido principal -->
        <div id="content" class="content">
            @RenderBody()
        </div>

    </div>

    <!-- scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>