@model List<EscalationAnalysisDb2.Domain.Entities.Report>

@{
    // titulo de la pagina
    ViewData["Title"] = "Report History";
}

<div class="card p-4 shadow-sm">

    <!-- encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>Report History</h4>

        <a asp-controller="Upload"
           asp-action="Index"
           class="btn btn-primary">
            Upload New Report
        </a>
    </div>

    @if (!Model.Any())
    {
        <p class="text-muted">No reports found.</p>
    }
    else
    {
        <div class="table-responsive">

            <!-- tabla de historial -->
            <table class="table table-bordered table-hover">

                <thead class="table-light">
                    <tr>
                        <th>File Name</th>

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- solo admin ve quien subio -->
                            <th>Uploaded By</th>
                        }

                        <th>Upload Date</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FileName</td>

                            @if (User.IsInRole("Admin"))
                            {
                                <td>@item.UploadedByUser.Email</td>
                            }

                            <td>@item.UploadDate.ToString("dd/MM/yyyy hh:mm tt")</td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    }

</div>