@{
    ViewData["Title"] = "System Overview";
}

<div class="container-fluid">

    <!-- encabezado -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color:#4c1d95;">System Overview</h2>
        <p class="text-muted mb-0">
            Administrative metrics and platform activity
        </p>
    </div>

    <!-- tarjetas principales -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">Total Users</small>
                <h2 class="fw-bold mb-0">@ViewBag.TotalUsers</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">Active Users</small>
                <h2 class="fw-bold text-success mb-0">@ViewBag.ActiveUsers</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">Inactive Users</small>
                <h2 class="fw-bold text-danger mb-0">
                    @(ViewBag.TotalUsers - ViewBag.ActiveUsers)
                </h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <small class="text-muted">Total Reports</small>
                <h2 class="fw-bold mb-0">@ViewBag.TotalReports</h2>
            </div>
        </div>

    </div>

    <!-- segunda fila -->
    <div class="row g-3 mb-4">

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <h5 class="mb-3">Last Upload</h5>

                <h4 class="fw-bold" style="color:#4c1d95;">

                    @(
                        ViewBag.LastUpload == DateTime.MinValue
                        ? "N/A"
                        : ((DateTime)ViewBag.LastUpload).ToString("dd/MM/yyyy HH:mm")
                        )

                </h4>

                <small class="text-muted">
                    Most recent uploaded report in the platform
                </small>

            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <h5 class="mb-3">Quick Status</h5>

                <div class="mb-2 d-flex justify-content-between">
                    <span>Total Accounts Enabled</span>
                    <strong>@ViewBag.ActiveUsers</strong>
                </div>

                <div class="mb-2 d-flex justify-content-between">
                    <span>Total Accounts Disabled</span>
                    <strong>
                        @(ViewBag.TotalUsers - ViewBag.ActiveUsers)
                    </strong>
                </div>

                <div class="d-flex justify-content-between">
                    <span>Reports Loaded</span>
                    <strong>@ViewBag.TotalReports</strong>
                </div>

            </div>
        </div>

    </div>

    <!-- reportes recientes -->
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Recent Reports</h5>
            <small class="text-muted">Latest 5 uploads</small>
        </div>

        <div class="table-responsive">

            <table class="table align-middle table-hover">

                <thead class="table-light">
                    <tr>
                        <th>File Name</th>
                        <th>Uploaded By</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>

                    @if (ViewBag.RecentReports != null && ViewBag.RecentReports.Count > 0)
                    {
                        @foreach (var report in ViewBag.RecentReports)
                        {
                            <tr>
                                <td>@report.FileName</td>
                                <td>@report.UploadedByUser?.Email</td>
                                <td>@report.UploadDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted">
                                No reports found.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- reglas -->
    <div class="row g-3">

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <h5>User Rules</h5>

                <ul class="mb-0">
                    <li>Only valid emails can be registered.</li>
                    <li>Inactive users cannot log in.</li>
                    <li>Admin users manage accounts and reports.</li>
                    <li>User accounts have limited permissions.</li>
                </ul>

            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">

                <h5>Operational Notes</h5>

                <ul class="mb-0">
                    <li>Review uploads periodically.</li>
                    <li>Keep user list updated.</li>
                    <li>Validate files before upload.</li>
                    <li>Monitor report activity monthly.</li>
                </ul>

            </div>
        </div>

    </div>

</div>