<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EscalationAnalysisDb2</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas"></script>
</head>

<body>

    <div class="topbar">
        <div class="d-flex align-items-center w-100 justify-content-between">

            <div class="d-flex align-items-center gap-3">
                <span onclick="toggleSidebar()" style="font-size:20px; cursor:pointer;">☰</span>
                <span style="font-size:22px; font-weight:500;">Logo</span>
            </div>

            <div class="d-flex align-items-center gap-3">

                @if (User.Identity.IsAuthenticated)
                {
                    <span style="color:white; font-weight:500;">
                        Hi, @User.Identity.Name
                    </span>

                    <a href="/Auth/Logout" class="btn btn-outline-light btn-sm">
                        Logout
                    </a>
                }

            </div>

        </div>
    </div>

    <div class="main-container">

        <div id="sidebar" class="sidebar">
            <h4>IBM</h4>

            <ul>
                <li><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li><a asp-controller="Upload" asp-action="Index">Upload</a></li>

                @if (User.IsInRole("Admin"))
                {
                    <li><a asp-controller="Users" asp-action="Index">Users</a></li>
                }
            </ul>
        </div>

        <div id="content" class="content">
            @RenderBody()
        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>