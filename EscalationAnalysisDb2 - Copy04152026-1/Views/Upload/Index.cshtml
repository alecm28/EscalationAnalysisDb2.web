@{
    ViewData["Title"] = "Upload";
}

<div class="row">
    <div class="col-md-6">

        <div class="card p-4">

            <h5 class="mb-2">Upload File</h5>
            <p class="text-muted mb-4">
                Upload your escalation report (CSV or Excel)
            </p>

            <!-- FIX: controller + enctype correcto -->
            <form asp-controller="Upload" asp-action="UploadFile" method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <input type="file" name="file" class="form-control" />
                </div>

                <!-- FIX: type submit -->
                <button type="submit" class="btn btn-primary w-100">
                    Upload
                </button>

            </form>

        </div>

        <div class="mt-3">
            <!-- FIX: ruta correcta -->
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
                Back to Dashboard
            </a>
        </div>

    </div>
</div>